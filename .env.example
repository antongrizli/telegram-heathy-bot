# Telegram Bot Token (obtain from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Gemini API Credentials (obtain from Google AI Studio)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere
GEMINI_MODEL=gemma-4-31b-it

# List of Telegram user IDs with Admin privileges (comma-separated)
ADMIN_USER_IDS=987654321,123456789

# Database URL configuration (points to localhost for local testing, overridden in docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5432/healthy_bot

# Postgres config (used by docker-compose)
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=healthy_bot
